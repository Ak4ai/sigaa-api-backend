NODE_ENV=development
# development  → Windows local (Chrome abre visível)
# vps          → Linux VPS / Oracle Cloud / DigitalOcean (Chrome via apt)
# production   → Vercel serverless (@sparticuz/chromium)

# Segredo para JWT (pode ser qualquer string)
SECRET=seu_segredo_jwt_aqui

# Exatamente 32 caracteres para AES-256 (senha do aluno)
ENC_SECRET=SuaChaveAES256_Senha_32chars!!!!

# Exatamente 32 caracteres para AES-256 (usuário/CPF do aluno)
ENC_SECRET_USER=SuaChaveAES256_User__32chars!!!!

# (Opcional) Caminho do Chrome no Linux — detectado automaticamente se não definido
# CHROME_PATH=/usr/bin/chromium-browser
